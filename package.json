{
  "name": "udemy-enroller-frontend-assets",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build:css:app": "tailwindcss -c tailwind.config.js -i ./app/static/css/tailwind.input.css -o ./app/static/css/tailwind.min.css --minify",
    "build:css:home": "tailwindcss -c tailwind.home.config.js -i ./app/static/css/tailwind.input.css -o ./app/templates/components/tailwind-home.min.css --minify",
    "build:css": "npm run build:css:app && npm run build:css:home",
    "audit:performance": "node tests/performance-audit.js",
    "audit:performance:baseline": "node tests/performance-audit.js --write-baseline",
    "audit:performance:check": "node tests/performance-audit.js --check"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "playwright": "^1.61.1",
    "tailwindcss": "^3.4.17"
  }
}
