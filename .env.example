# Application Configuration
APP_NAME=Udemy Course Enroller
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-me-to-a-random-string-in-production
COOKIE_SECURE=false

# Cookie encryption key — must be a valid Fernet key (32 bytes base64-encoded).
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left empty, the app will derive a key from SECRET_KEY (not recommended for production).
COOKIE_ENCRYPTION_KEY=

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_HOSTS=*
DEPLOYMENT_ENV=local  # "local" or "server" (server=stricter rate limits + secure cookies)

# CORS Configuration
# Comma-separated list of allowed origins (development: http://localhost:3000,http://localhost:8000)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database (SQLite for simplicity, can be changed to PostgreSQL)
DATABASE_URL=sqlite:///./udemy_enroller.db
# Keep false when using Alembic migrations; true is only for legacy bootstrap.
AUTO_CREATE_TABLES=false

# For PostgreSQL on Digital Ocean:
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Logging Configuration
# LOG_LEVEL: WARNING (default), INFO (more verbose), DEBUG (most verbose)
# SECURITY: Setting LOG_LEVEL to INFO or DEBUG will expose sensitive data in logs.
# Only use higher verbosity in development. Production should remain at WARNING.
LOG_LEVEL=WARNING
LOG_FILE=logs/app.log
LOG_FORMAT=json  # Options: "json" or "text"

# Google Search Console verification (set after creating a GSC property)
GOOGLE_SITE_VERIFICATION=

# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
GTM_CONTAINER_ID=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# Used for direct GA4 tracking — works independently of GTM
GA4_MEASUREMENT_ID=

# Redis (optional, for task queue)
REDIS_URL=redis://localhost:6379/0

# Optional: Pre-configured Udemy credentials
# SECURITY: Storing passwords in environment files is insecure.
# Use Cookie Login (access_token, client_id, csrftoken) instead.
# See /guides for instructions on extracting session cookies safely.
UDEMY_EMAIL=
UDEMY_PASSWORD=

# Scraper settings
MAX_SCRAPER_WORKERS=5
SCRAPER_SITE_TIMEOUT_SECONDS=1800
SCRAPER_RUN_TIMEOUT_SECONDS=2700
SCRAPER_TIMEOUT=30

# Optional: Comma-separated list of proxies for network flexibility
# Format: http://user:pass@host:port,socks5://user:pass@host:port
# NOTE: Use proxies only for legitimate network requirements (e.g., corporate
# networks, geographic access). Do not use for rate-limit evasion or IP rotation.
PROXIES=
