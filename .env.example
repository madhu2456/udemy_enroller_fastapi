# Application Configuration
APP_NAME=Udemy Course Enroller
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-me-to-a-random-string-in-production
COOKIE_SECURE=false

# Server
HOST=0.0.0.0
PORT=8000

# CORS Configuration
# Comma-separated list of allowed origins (development: http://localhost:3000,http://localhost:8000)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database (SQLite for simplicity, can be changed to PostgreSQL)
DATABASE_URL=sqlite:///./udemy_enroller.db
# Keep false when using Alembic migrations; true is only for legacy bootstrap.
AUTO_CREATE_TABLES=false

# For PostgreSQL on Digital Ocean:
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Logging Configuration
LOG_LEVEL=WARNING
LOG_FILE=logs/app.log
LOG_FORMAT=json  # Options: "json" or "text"

# Optional: Pre-configured Udemy credentials
UDEMY_EMAIL=
UDEMY_PASSWORD=

# Scraper settings
MAX_SCRAPER_WORKERS=5
SCRAPER_TIMEOUT=30

# Optional: Comma-separated list of proxies for scrapers to rotate
# Format: http://user:pass@host:port,socks5://user:pass@host:port
PROXIES=
